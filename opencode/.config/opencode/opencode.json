{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow",
    "doom_loop": "ask",
    "external_directory": "deny"
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide"
      ],
      "enabled": false
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "ibm/granite-4-h-tiny": {
          "name": "Granite-4-h-tiny (local)"
        },
        "openai/gpt-oss-20b": {
          "name": "gpt-oss-20b (local)"
        },
        "qwen/qwen3-coder-30b": {
          "name": "qwen3-coder-30b (local)"
        },
        "essentialai/rnj-1": {
          "name": "rnj-1 (local)"
        },
        "qwen/qwen3-vl-8b": {
          "name": "qwen/qwen3-vl-8b (local)"
        }
      }
    }
  }
}
